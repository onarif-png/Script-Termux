    print("  " + DM + "-" * 46 + RS)
    for i, h in enumerate(top, 1):
        print(f"  {i}. {BD}{h['s']:<8}{RS}  {h['n']:<35}  {Y}{h['w']:>6}{RS}")
    print()

# ── Similar ETFs by industry profile ─────────────────────────
try:
    import pandas as pd
    from collections import Counter

    map_files = sorted(glob.glob(str(SCRIPT_DIR.parent / "etf_holdings_map_*.csv")))
    etf_csv   = sorted(glob.glob(str(CSV_DIR / "screener-etf-*.csv")) +
                       glob.glob(str(CSV_DIR / "screener-etf-for-ranking-*.csv")))
    stock_files = sorted(glob.glob(str(CSV_DIR / "screener-stocks-*.csv")))

    if map_files and etf_csv and stock_files:
        map_df = pd.read_csv(map_files[-1])
        edf    = pd.read_csv(etf_csv[-1], low_memory=False)
        sdf    = pd.read_csv(stock_files[-1], low_memory=False)
        edf.columns = [c.strip() for c in edf.columns]
        sdf.columns = [c.strip() for c in sdf.columns]

        sym_col  = next((c for c in edf.columns if c.lower() == "symbol"), None)
        ast_col  = next((c for c in edf.columns if c.lower() == "assets"), None)
        name_col = next((c for c in edf.columns if "fund name" in c.lower()), None)
        pe_col   = next((c for c in edf.columns if c.lower() == "pe ratio"), None)
        s_sym    = next((c for c in sdf.columns if c.lower() == "symbol"), None)
        s_ind    = next((c for c in sdf.columns if c.lower() == "industry"), None)

        # Build stock→industry map
        sym_to_ind = {}
        if s_sym and s_ind:
            for _, row in sdf.iterrows():
                s = str(row[s_sym]).strip().upper()
                ind = str(row[s_ind]).strip() if pd.notna(row[s_ind]) else ""
                if ind and ind.lower() not in ("nan","n/a",""):
                    sym_to_ind[s] = ind

        # Build all ETF industry profiles in one pass
        all_profiles = {}
        for etf_sym, grp in map_df.groupby("ETF"):
            counts = Counter()
            for s in grp["Symbol"]:
                if not isinstance(s, str): continue
                ind = sym_to_ind.get(s.strip().upper(), "")
                if ind: counts[ind] += 1
            total = sum(counts.values())
            if total > 0:
                all_profiles[etf_sym] = {ind: cnt/total for ind, cnt in counts.items()}

        # Get target ETF's top industries (those ≥5% weight)
        target_profile = all_profiles.get(tk, {})
        top_industries = {ind for ind, pct in target_profile.items() if pct >= 0.05}

        if target_profile and top_industries:
            scores = []
            for etf2, profile2 in all_profiles.items():
                if etf2 == tk: continue
                score = sum(
                    min(target_profile.get(ind, 0), profile2.get(ind, 0))
                    for ind in top_industries
                ) * 100
                if score > 5:
                    scores.append((etf2, round(score, 1)))

            scores.sort(key=lambda x: -x[1])
            top_similar = scores[:5]

            if top_similar:
                print("  " + BD + Y + "SIMILAR ETFs  (by industry profile)" + RS)
                print("  " + DM + "-" * 72 + RS)
                print("  {:<8}  {:<38}  {:>8}  {:>6}  {:>8}".format("Ticker", "Fund Name", "Assets", "PE", "Match"))
                print("  " + DM + "-" * 72 + RS)
                for sym2, score in top_similar:
                    row2  = edf[edf[sym_col].str.upper() == sym2] if sym_col else pd.DataFrame()
                    name2 = str(row2.iloc[0][name_col]).strip()[:38] if name_col and not row2.empty else ""
                    try:
                        a = pd.to_numeric(row2.iloc[0][ast_col], errors="coerce") if not row2.empty else 0
                        a_str = f"${a/1e9:.1f}B" if a >= 1e9 else f"${a/1e6:.0f}M" if a >= 1e6 else "N/A"
                    except: a_str = "N/A"
                    try:   p_str = f"{float(row2.iloc[0][pe_col]):.1f}x" if pe_col and not row2.empty else "N/A"
                    except: p_str = "N/A"
                    print(f"  {sym2:<8}  {name2:<38}  {a_str:>8}  {p_str:>6}  {score:>6.1f}%")
                print()
except Exception as e:
    pass


