#!/usr/bin/env python3
import sys, re, warnings, glob
from pathlib import Path
warnings.filterwarnings("ignore")
import requests
from bs4 import BeautifulSoup

HEADERS = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}
BD = "\033[1m"; Y = "\033[93m"; G = "\033[92m"; R = "\033[91m"; DM = "\033[2m"; RS = "\033[0m"

# ── Paths (same folder as this script) ────────────────────────
SCRIPT_DIR = Path(__file__).resolve().parent
CSV_DIR    = SCRIPT_DIR.parent / "CSV TICKER LISTS"

def fetch(url):
    try:
        r = requests.get(url, headers=HEADERS, timeout=15)
        return BeautifulSoup(r.text, "html.parser") if r.status_code == 200 else None
    except: return None

def get_pairs(soup):
    d = {}
    for t in soup.find_all("table"):
        for row in t.find_all("tr"):
            c = row.find_all("td")
            if len(c) == 2: d[c[0].get_text(strip=True)] = c[1].get_text(strip=True)
    return d

def get_holdings(soup, n=5):
    h = []
    for t in soup.find_all("table"):
        hdr = " ".join(th.get_text(strip=True) for th in t.find_all("th"))
        if "Weight" in hdr and "Name" in hdr:
            for row in t.find_all("tr")[1:]:
                c = row.find_all("td")
                if len(c) >= 3:
                    if c[0].get_text(strip=True).isdigit():
                        h.append({"s": c[1].get_text(strip=True), "n": c[2].get_text(strip=True), "w": c[3].get_text(strip=True) if len(c)>3 else ""})
                    else:
                        h.append({"s": c[1].get_text(strip=True), "n": c[0].get_text(strip=True), "w": c[2].get_text(strip=True)})
                if len(h) >= n: break
            break
    return h

def get_hstats(soup):
    s, text = {}, soup.get_text(" ", strip=True)
    for k, p in {"Total Holdings": r"Total Holdings\s+(\d[\d,]*)", "Top 10 Percentage": r"Top 10 Percentage\s+([\d.]+%)", "Asset Class": r"Asset Class\s+(\w[\w\s]*?)(?=ETF Category|Assets|PE Ratio|$)", "Assets": r"Assets\s+(\$?[\d,.]+[BMK]?)", "PE Ratio": r"PE Ratio\s+([\d.]+)"}.items():
        m = re.search(p, text)
        if m: s[k] = m.group(1).strip()
    return s

def wrap(text):
    line = "  "
    for w in text.split():
        if len(line) + len(w) + 1 > 62:
            print(line); line = "  " + w
        else: line = line + " " + w if line.strip() else "  " + w
    if line.strip(): print(line)

if len(sys.argv) < 2:
    print(R + "Usage: etf <TICKER>" + RS); sys.exit(1)

tk = sys.argv[1].strip().upper()
print("\n" + DM + "Looking up " + BD + tk + RS + DM + "..." + RS)

ov = fetch("https://stockanalysis.com/etf/" + tk.lower() + "/")
hl = fetch("https://stockanalysis.com/etf/" + tk.lower() + "/holdings/")
if not ov: print(R + "  Not found or failed." + RS); sys.exit(1)

st = get_pairs(ov)
top = get_holdings(ov, 5)
hs = get_hstats(hl) if hl else {}
if len(top) < 5 and hl: top = get_holdings(hl, 5)

th = st.get("Holdings", hs.get("Total Holdings", "N/A"))
t10 = hs.get("Top 10 Percentage", "N/A")
pe = st.get("PE Ratio", hs.get("PE Ratio", "N/A"))
beta = st.get("Beta", "N/A")
assets = st.get("Assets", hs.get("Assets", "N/A"))
ac = hs.get("Asset Class", "equity")

t5 = ", ".join(h["n"] + " (" + h["s"] + ") at " + h["w"] for h in top)

print()
# Get fund full name from screener CSV
import glob as _g, pandas as _pd
from pathlib import Path as _P
_CSV = _P(__file__).parent.parent / "CSV TICKER LISTS"
_ef = sorted(_g.glob(str(_CSV / "screener-etf-*.csv")) + _g.glob(str(_CSV / "screener-etf-for-ranking-*.csv")))
_fund_name = ""
if _ef:
    try:
        _edf = _pd.read_csv(_ef[-1], low_memory=False)
        _edf.columns = [c.strip() for c in _edf.columns]
        _sc = next((c for c in _edf.columns if c.lower()=="symbol"), None)
        _nc = next((c for c in _edf.columns if "fund name" in c.lower()), None)
        if _sc and _nc:
            _row = _edf[_edf[_sc].str.upper()==tk]
            if not _row.empty: _fund_name = str(_row.iloc[0][_nc]).strip()
    except: pass
if _fund_name:
    print("  " + BD + Y + tk + " — " + _fund_name + RS)
print("  " + BD + Y + tk + " SUMMARY" + RS)
print("  " + DM + "-" * 56 + RS)
# Quick top-industry for summary
_top_ind_str = ""
try:
    import glob as _gl, pandas as _pd2
    _mf = sorted(_gl.glob(str(SCRIPT_DIR.parent / "etf_holdings_map_*.csv")))
    if _mf:
        _md = _pd2.read_csv(_mf[-1])
        _syms = _md[_md["ETF"]==tk]["Symbol"].tolist()
        _sdf2 = None
        _csv2 = sorted(_gl.glob(str(SCRIPT_DIR.parent / "CSV TICKER LISTS" / "screener-stocks-*.csv")))
        if _csv2: _sdf2 = _pd2.read_csv(_csv2[-1])
        if _sdf2 is not None:
            _ic = next((c for c in _sdf2.columns if c.lower()=="industry"), None)
            _sc2 = next((c for c in _sdf2.columns if c.lower()=="symbol"), None)
            if _ic and _sc2:
                _rows = _sdf2[_sdf2[_sc2].isin(_syms)]
                _cnts = _rows[_ic].value_counts()
                if not _cnts.empty:
                    _top_i = _cnts.index[0]
                    _top_p = _cnts.iloc[0] / len(_rows) * 100
                    _top_ind_str = f" Top industry: {_top_i} ({_top_p:.0f}%)."
except: pass
s = tk + " is a " + str(th) + "-stock " + ac.lower() + " ETF"
s += f" ({assets}, PE {pe}, beta {beta})."
s += " Top 5: " + t5 + "."
if _top_ind_str: s += _top_ind_str
wrap(s)
print()

# ── Table format summary ──────────────────────────────────────
print("  " + BD + Y + tk + " AT A GLANCE" + RS)
print("  " + DM + "-" * 46 + RS)
summary_rows = [
    ("Total Holdings",  str(th)),
    ("PE Ratio",        str(pe)),
    ("Beta",            str(beta)),
    ("Total Assets",    str(assets)),
    ("Top 10 Weight",   t10),
]
for label, val in summary_rows:
    if val and val != "N/A":
        print(f"  {label:<20}  {Y}{val}{RS}")
print()

# ── Top 5 Holdings ────────────────────────────────────────────
if top:
